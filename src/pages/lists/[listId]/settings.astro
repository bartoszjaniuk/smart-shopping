---
import Layout from "../../../layouts/Layout.astro";
import AppShellLayout from "../../../layouts/AppShellLayout.astro";
import ListSettingsView from "../../../components/lists/ListSettingsView.tsx";

const { listId } = Astro.params;
if (!listId) {
  throw new Error("Parametr listId jest wymagany dla trasy /lists/:listId/settings");
}
---

<Layout title="Ustawienia listy – SmartShopping">
  <AppShellLayout pageTitle="Ustawienia listy" activeRoute="/lists" mobileBackHref={`/lists/${listId}`}>
    <ListSettingsView client:load listId={listId} />
  </AppShellLayout>
</Layout>
