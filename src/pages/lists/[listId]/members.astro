---
import Layout from "../../../layouts/Layout.astro";
import AppShellLayout from "../../../layouts/AppShellLayout.astro";
import MembersView from "../../../components/lists/MembersView.tsx";

const { listId } = Astro.params;
if (!listId) {
  throw new Error("Parametr listId jest wymagany dla trasy /lists/:listId/members");
}
---

<Layout title="Członkowie listy – SmartShopping">
  <AppShellLayout pageTitle="Członkowie listy" activeRoute="/lists" mobileBackHref={`/lists/${listId}`}>
    <MembersView client:load listId={listId} />
  </AppShellLayout>
</Layout>
