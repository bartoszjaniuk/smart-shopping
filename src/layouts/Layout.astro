---
import "../styles/global.css";
import { PwaRegister } from "../components/PwaRegister";

export interface Props {
  title?: string;
  description?: string;
}

const { title = "SmartShopping", description } = Astro.props;

const themeInitScript = `
(function() {
  var stored = localStorage.getItem("theme");
  var dark = stored === "dark" || (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches);
  document.documentElement.classList.toggle("dark", dark);
  if (stored) document.documentElement.dataset.theme = stored;
})();
`;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" sizes="192x192" href="/pwa/icon-192x192.png" />
    <link rel="apple-touch-icon" sizes="192x192" href="/pwa/maskable-icon-192x192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="SmartShopping" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <script is:inline set:html={themeInitScript} />
  </head>
  <body class="min-h-screen">
    <PwaRegister client:load />
    <slot />
  </body>
</html>
